# Database (MySQL / MariaDB)
DATABASE_URL=mysql://root:@localhost:3306/streamyolo_dev

# Server
PORT=3001
SESSION_SECRET=change-me-in-production-min-32-chars
CORS_ORIGIN=http://localhost:5173

# LiveKit
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# CCBill
CCBILL_CLIENT_ACCOUNT_NUMBER=your-client-account
CCBILL_SUBCLIENT_ACCOUNT_NUMBER=your-subclient-account
CCBILL_DATALINK_USERNAME=your-datalink-username
CCBILL_DATALINK_PASSWORD=your-datalink-password
CCBILL_WEBHOOK_SECRET=your-webhook-secret
CCBILL_FLEXFORM_ID=your-flexform-id

# Object Storage
# For local dev, set STORAGE_LOCAL_PATH to a directory on disk and leave S3 vars empty
STORAGE_LOCAL_PATH=./uploads

# For production (S3-compatible)
STORAGE_ENDPOINT=https://your-s3-endpoint
STORAGE_BUCKET=streamyolo-media
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_BASE_URL=https://media.yourdomain.com

# Web
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001
VITE_LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
